# ── MySQL ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=echo_db
DB_USER=root
DB_PASSWORD=

# ── Storage ────────────────────────────────────────────
# "local" stores files in ./uploads/  (dev default)
# "s3"    uploads to AWS S3
STORAGE_BACKEND=local
UPLOAD_DIR=uploads
PUBLIC_BASE_URL=http://localhost:8000/uploads

# S3 (required only when STORAGE_BACKEND=s3)
# S3_BUCKET=echo-audio
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=us-east-1

# ── Moderation ─────────────────────────────────────────
# "simple" uses keyword blocklist  (dev default)
# "openai" calls Whisper + Perspective API
MODERATION_BACKEND=simple
# OPENAI_API_KEY=sk-...